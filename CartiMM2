            return
        end

        if bridge.Parent or overlay.Parent then
            CartiHubCleanupRequestAcceptBridge()
        end
    end)
end

showIncomingTradeRequest = function()
    local moduleSenderName = pickFakeTradeSenderName()
    installRequestAcceptBridge()
    tradeModule.UpdateTradeRequestWindow("ReceivingRequest", {
        Sender = {
            Name = moduleSenderName,
        },
    })

    if _G.CartiHubPendingFakeTradeUsername then
        CartiHubApplyPendingRequestUsername(moduleSenderName)
        task.defer(function()
            CartiHubApplyPendingRequestUsername(moduleSenderName)
        end)
        task.delay(0.25, function()
            CartiHubApplyPendingRequestUsername(moduleSenderName)
        end)
    end
end

function CartiHubLaunchUpgradeFakeTrade(username)
    if not username or username == "" then
        return false
    end

    _G.CartiHubAutoTradeSearchPending = nil
    _G.CartiHubPendingFakeTradeUsername = username
    _G.CartiHubActiveFakeTradeUsername = username
    showIncomingTradeRequest()
    return true
end

