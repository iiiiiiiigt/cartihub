            playerButton.MouseButton1Click:Connect(function()
                CartiHubSetSelectedUpgradePlayer(player.Name)
                CartiHubRefreshUpgradePlayerDropdown()
            end)
        end
    end

    if not selectedStillHere then
        CartiHubSetSelectedUpgradePlayer(nil)
