    PopupAmountLabel.Text = "Spawn Amount: " .. value
    PopupSliderKnob.Text = tostring(value)
    PopupSliderFill.Size = UDim2.new((value - minAmount) / (maxAmount - minAmount), 0, 1, 0)
end

