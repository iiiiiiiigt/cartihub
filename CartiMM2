local function copyItemData(itemId, itemType, amount)
    local source = sync[itemType] and sync[itemType][itemId]
    if not source then
        return nil
    end

    local data = {}
    for key, value in pairs(source) do
        data[key] = value
    end

    data.DataType = itemType
    data.Amount = amount or 1
    return data
end

